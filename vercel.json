{
  "redirects": [
    { "source": "/(.*)", "has": [{"type": "host", "value": "vastorg.fr"}],     "destination": "https://www.vastorg.com/$1", "permanent": true },
    { "source": "/(.*)", "has": [{"type": "host", "value": "www.vastorg.fr"}], "destination": "https://www.vastorg.com/$1", "permanent": true },
    { "source": "/(.*)", "has": [{"type": "host", "value": "vastorg.eu"}],     "destination": "https://www.vastorg.com/$1", "permanent": true },
    { "source": "/(.*)", "has": [{"type": "host", "value": "www.vastorg.eu"}], "destination": "https://www.vastorg.com/$1", "permanent": true },
    { "source": "/(.*)", "has": [{"type": "host", "value": "vastorg.ch"}],     "destination": "https://www.vastorg.com/$1", "permanent": true },
    { "source": "/(.*)", "has": [{"type": "host", "value": "www.vastorg.ch"}], "destination": "https://www.vastorg.com/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/guide",      "destination": "/guide/index.html" },
    { "source": "/guide/(.*)", "destination": "/guide/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
